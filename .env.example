# Copy to .env for local runs. Placeholders only — real values live in
# `fly secrets` (deploy) and GitHub Actions secrets (CI). The eval gate is
# keyless by design, so CI needs NONE of these.

# --- Local embedding (dev): Ollama, keyless, free ---
# The committed fixtures + query embeddings are nomic-embed-text @ 768 dims.
OLLAMA_URL=http://127.0.0.1:11434
VRAG_EMBED_MODEL=nomic-embed-text

# --- Qdrant (dense vectors) ---
# Local dev uses qdrant-client local mode (no server). Deploy reaches the Fly
# machine privately over .flycast.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=__set_in_fly_secrets__

# --- Neon Postgres (metadata + tsvector lexical arm) ---
# Pooled URL (-pooler host) at runtime; direct URL for DDL / pg_dump.
NEON_DATABASE_URL=postgresql://user:__password__@__host__-pooler.neon.tech/vrag?sslmode=require
NEON_DIRECT_URL=postgresql://user:__password__@__host__.neon.tech/vrag?sslmode=require

# --- FastAPI <-> backend ---
VRAG_REMOTE_TOKEN=__bearer_token__
